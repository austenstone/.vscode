{
	"servers": {
		"mcp-apps-playground": {
			"type": "stdio",
			"command": "node",
			"args": [
				"~/source/mcp-apps-playground/dist/index.js"
			]
		},
		"time": {
			"command": "uvx",
			"args": [
				"mcp-server-time",
				"--local-timezone",
				"America/New_York"
			],
			"type": "stdio"
		},
		"github-mcp-server": {
			"url": "https://api.githubcopilot.com/mcp",
			"headers": {
				"X-MCP-Toolsets": "default,orgs"
			},
			"type": "http"
		},
		"github-context": {
			"url": "https://api.githubcopilot.com/mcp/x/context",
			"type": "http"
		},
		"github-spaces": {
			"url": "https://api.githubcopilot.com/mcp/x/copilot_spaces",
			"type": "http"
		},
		"github-security": {
			"url": "https://api.githubcopilot.com/mcp",
			"headers": {
				"X-MCP-Toolsets": "code_security,dependabot,secret_protection,security_advisories"
			},
			"type": "http"
		},
		"github-actions": {
			"url": "https://api.githubcopilot.com/mcp/x/actions",
			"type": "http"
		},
		"github-copilot": {
			"url": "https://api.githubcopilot.com/mcp",
			"headers": {
				"X-MCP-Toolsets": "copilot,copilot_spaces,github_support_docs_search"
			},
			"type": "http"
		},
		"github-projects": {
			"url": "https://api.githubcopilot.com/mcp/x/projects",
			"type": "http"
		},
		"github-discussions": {
			"url": "https://api.githubcopilot.com/mcp/x/discussions",
			"type": "http"
		},
		"github-other": {
			"url": "https://api.githubcopilot.com/mcp",
			"headers": {
				"X-MCP-Toolsets": "stargazers,notifications,labels,gists,git"
			},
			"type": "http"
		},
		"github-read-only": {
			"url": "https://api.githubcopilot.com/mcp/x/all/readonly",
			"type": "http"
		},
		// "Primer": {
		// 	"type": "stdio",
		// 	"command": "npx",
		// 	"args": [
		// 		"@primer/mcp@latest"
		// 	]
		// },
		// "chrome-devtools": {
		// 	"command": "npx",
		// 	"args": [
		// 		"-y",
		// 		"chrome-devtools-mcp@latest",
		//     "--autoConnect",
		//     // "--channel=beta"
		// 	],
		// 	"type": "stdio"
		// },
		"firecrawl-mcp": {
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp"
			],
			"env": {
				"FIRECRAWL_API_KEY": "${input:FIRECRAWL_API_KEY}"
			},
			"type": "stdio"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.30"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.30"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com"
		},
		"microsoft/playwright-extension": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest",
				"--extension"
			],
			"env": {
				"PLAYWRIGHT_MCP_EXTENSION_TOKEN": "${input:playwright-key}"
			}
		},
		"brave-search": {
			"command": "npx",
			"args": [
				"-y",
				"@brave/brave-search-mcp-server",
				"--transport",
				"stdio"
			],
			"env": {
				"BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
			},
			"type": "stdio"
		},
		// "myinstants": {
		// 	"command": "npx",
		// 	"args": [
		// 		"-y",
		// 		"myinstants-mcp@latest"
		// 	],
		// 	"type": "stdio"
		// },
		"workiq": {
			"command": "npx",
			"args": [
				"-y",
				"@microsoft/workiq",
				"mcp"
			],
			"type": "stdio",
			"tools": [
				"*"
			]
		},
		"notebooklm": {
			"command": "npx",
			"args": [
				"notebooklm-mcp@latest"
			],
			"type": "stdio"
		},
		"nanobanana": {
			"type": "stdio",
			"command": "node",
			"args": [
				"~/source/nanobanana/mcp-server/dist/index.js"
			],
			"env": {
				"GEMINI_API_KEY": "${input:GEMINI_API_KEY}"
			}
		},
		"splunk": {
			"type": "stdio",
			"command": "python3",
			"args": [
				"/Users/austenstone/source/llm-assist/tools/mcp_splunk_readonly_server.py"
			]
		},
		"highcharts": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-highcharts@latest"
			],
			"env": {
    		// "HIGHCHARTS_THEME": "/Users/austenstone/source/austenstone-notes/.vscode/github-theme.json"
			}
		}
	},
	"inputs": [
		{
			"id": "tfe_token",
			"type": "promptString",
			"description": "Terraform API Token",
			"password": true
		},
		{
			"id": "tfe_hostname",
			"type": "promptString",
			"description": "Terraform hostname",
			"password": false
		},
		{
			"type": "promptString",
			"id": "FIRECRAWL_API_KEY",
			"description": "FIRECRAWL_API_KEY",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		},
		{
			"id": "Authorization",
			"type": "promptString",
			"description": "Authentication token (PAT or App token)",
			"password": true
		},
		{
			"password": true,
			"id": "brave-api-key",
			"type": "promptString",
			"description": "Brave Search API Key"
		},
		{
			"password": true,
			"id": "playwright-key",
			"type": "promptString",
			"description": "Browser key auth"
		},
		{
			"id": "GEMINI_API_KEY",
			"type": "promptString",
			"description": "Gemini API Key",
			"password": true
		}
	]
}